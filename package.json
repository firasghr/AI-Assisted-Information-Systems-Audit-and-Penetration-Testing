{
  "name": "ai-assisted-pentest",
  "version": "1.0.0",
  "description": "AI-Assisted Information Systems Audit and Penetration Testing - Capstone Project",
  "main": "src/api/app.js",
  "scripts": {
    "start": "node src/api/app.js",
    "dev": "nodemon src/api/app.js",
    "test": "jest --testPathPattern=tests/ --forceExit",
    "lint": "eslint src/ tests/ --ext .js",
    "normalize": "node src/normalizer/normalizer.js",
    "analyze": "node src/ai/ai_analyzer.js",
    "compare": "node src/comparison/comparison_engine.js",
    "report": "node src/report/report_generator.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "openai": "^4.20.0",
    "pdfkit": "^0.14.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": [
      "**/tests/**/*.js",
      "**/?(*.)+(spec|test).js"
    ]
  }
}
